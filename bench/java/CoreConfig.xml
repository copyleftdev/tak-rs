<?xml version="1.0" encoding="UTF-8"?>
<!--
    Minimal CoreConfig.xml for the M5 firehose comparison.
    No TLS, no auth, no LDAP, no federation — just the streaming-TCP CoT
    input on 8088 + a Postgres connection. Matches what tak-rs's plain
    firehose does so the comparison is apples-to-apples.

    See docs/perf-comparison.md and bench/java/README.md.
-->
<Configuration xmlns="http://bbn.com/marti/xml/config"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="CoreConfig.xsd">
    <network multicastTTL="5">
        <!-- Streaming TCP TAK Protocol v1 on 8088 (the firehose
             target). coreVersion="2" enables the v1 framing — without
             it the server expects bare-CoT-XML over the stream and
             closes the socket on the first protobuf frame it sees. -->
        <input _name="streamtcp" protocol="stcp" port="8088" auth="anonymous" coreVersion="2"/>
        <!-- Plain TCP single-event CoT on 8087 for parity. -->
        <input _name="stdtcp" protocol="tcp" port="8087" auth="anonymous"/>

        <!-- Web connectors required by the messaging service to come
             up. We don't use them in the bench but they have to bind. -->
        <connector port="8443" _name="https"/>
    </network>

    <auth default="file">
        <File location="UserAuthenticationFile.xml"/>
    </auth>

    <submission ignoreStaleMessages="false" validateXml="false"/>
    <buffer>
        <queue>
            <priority/>
        </queue>
        <latestSA enable="true"/>
    </buffer>

    <dissemination smartRetry="false"/>

    <!-- Persistence disabled for the bench. tak-rs's no-persist row
         is what we compare against; running Java in the same mode
         keeps the comparison fair AND skips the SchemaManager step
         (we never built it). -->
    <repository enable="false" numDbConnections="16" primaryKeyBatchSize="500" insertionBatchSize="500">
        <connection url="jdbc:postgresql://tak-database:5432/cot" username="martiuser" password="bench-only"/>
    </repository>

    <repeater enable="true" periodMillis="3000" staleDelayMillis="15000">
        <repeatableType initiate-test="/event/detail/emergency[@type='911 Alert']"
                        cancel-test="/event/detail/emergency[@cancel='true']" _name="911"/>
        <repeatableType initiate-test="/event/detail/emergency[@type='Ring The Bell']"
                        cancel-test="/event/detail/emergency[@cancel='true']" _name="RingTheBell"/>
        <repeatableType initiate-test="/event/detail/emergency[@type='Geo-fence Breached']"
                        cancel-test="/event/detail/emergency[@cancel='true']" _name="GeoFenceBreached"/>
        <repeatableType initiate-test="/event/detail/emergency[@type='Troops In Contact']"
                        cancel-test="/event/detail/emergency[@cancel='true']" _name="TroopsInContact"/>
    </repeater>

    <filter>
        <flowtag/>
        <streamingbroker enable="true"/>
        <scrubber enable="false" action="overwrite"/>
        <urladd enable="false"/>
    </filter>

    <buffer>
        <queue/>
        <latestSA enable="true"/>
    </buffer>

    <dissemination smartRetry="false"/>

    <security>
        <tls keystore="JKS" keystoreFile="certs/files/takserver.jks" keystorePass="atakatak"
             truststore="JKS" truststoreFile="certs/files/truststore-root.jks" truststorePass="atakatak"
             context="TLSv1.2" keymanager="SunX509"/>
    </security>

    <!-- Federation disabled — the bench is single-node and the
         federation manager's startup probe of SSLConfig races with
         our cert generation, making the messaging service NPE. -->
    <federation enableFederation="false"/>

    <plugins/>
    <cluster/>
    <vbm/>
</Configuration>
